# ─────────────────────────────────────────────────────────────────────────────
# LeasingDesk - Environment Variables
# Copy this file to .env.local for local development.
# NEVER commit .env.local to Git.

# Required - AI briefing, email fetch, weekly summary
ANTHROPIC_API_KEY=sk-ant-api03-...

# Google Sheets live data backend (optional but recommended)
GOOGLE_SHEETS_ID=
GOOGLE_API_KEY=AIza...

# Optional - set to "true" to skip API calls during development
VITE_DEMO_MODE=false
